# Hermes 프로필용 인증정보 템플릿.
# 설치 시 이 내용을 실제 값으로 채워 ~/.hermes/profiles/<프로필명>/.env 에
# 저장한다(Hermes가 세션/작업 실행 시 자동으로 로드). 저장소의 .env와는
# 별개 파일이다 — 헷갈리지 않도록 주의.
#
# 실제 값은 이 파일에도, 채팅에도 절대 입력하지 마세요.

# ---- Hermes 자체 LLM 백엔드 ----
# Nous Portal/OpenRouter/OpenAI 중 하나만 있으면 된다. 이 프로젝트는
# Claude(Anthropic)로 검증했다 — README "왜 Claude인가" 참고.
ANTHROPIC_API_KEY=여기에_실제_KEY_입력

# ---- KIS Open API (한국투자증권) ----
# 우리 저장소의 .env.example과 동일한 값 — 그대로 복사해서 채우면 된다.
KIS_APP_KEY=여기에_실제_APP_KEY_입력
KIS_APP_SECRET=여기에_실제_APP_SECRET_입력
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CD=01
KIS_ENV=vps

# ---- 키움증권 REST API ----
KIWOOM_APP_KEY=여기에_실제_APP_KEY_입력
KIWOOM_APP_SECRET=여기에_실제_SECRET_KEY_입력
KIWOOM_ENV=mock
