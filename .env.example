# KIS Open API 인증정보 템플릿.
# 이 파일을 복사해서 ".env"로 저장하고, 실제 값을 채워넣으세요.
# ".env"는 .gitignore에 등록되어 있어 git에 절대 올라가지 않습니다.
#
#   Windows(PowerShell): Copy-Item .env.example .env
#
# 실제 값은 여기(.env.example)에도, 채팅에도 절대 입력하지 마세요.

# KIS Developers 신청현황 화면에서 발급받은 값
KIS_APP_KEY=여기에_실제_APP_KEY_입력
KIS_APP_SECRET=여기에_실제_APP_SECRET_입력

# 계좌번호(예: 12345678-01)를 앞 8자리/뒤 2자리로 분리
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CD=01

# 실전투자(prod) 또는 모의투자(vps, paper trading) — 처음엔 vps 권장
KIS_ENV=vps

# 키움증권 REST API 신청 후 발급받은 값 (openapi.kiwoom.com)
KIWOOM_APP_KEY=여기에_실제_APP_KEY_입력
KIWOOM_APP_SECRET=여기에_실제_SECRET_KEY_입력

# 실전투자(prod) 또는 모의투자(mock) — 처음엔 mock 권장
KIWOOM_ENV=mock

# 금융감독원 OpenDART(opendart.fss.or.kr) — 이메일 가입 후 즉시 무료 발급
# 뉴스·펀더멘털 전략 트랙(PEAD, docs/news_fundamentals_전략_기획안.md)용
DART_API_KEY=여기에_실제_인증키_입력

# KRX 정보데이터시스템(data.krx.co.kr) 로그인 계정 — 외국인 수급(FFD) 전략
# 트랙(docs/foreign_flow_nat_전략_기획안.md §2.2/§8 게이트 0)용. API 키가
# 아니라 웹 로그인 아이디/비밀번호 그 자체이며, pykrx가 이 두 값을
# os.environ에서 직접 읽어 로그인 세션을 만든다. 주의(2026-07-17 기준):
# KRX가 2025-12-27부로 회원제 "데이터 마켓플레이스"로 개편되며 네이버/
# 카카오 간편로그인이 주 방식이 됐다 — 전통 아이디/비밀번호 가입 옵션이
# 있는지, 있다면 그 계정 정보를 아래에 채우세요(pykrx GitHub 이슈 #244,
# 이 메커니즘과의 호환 여부 미해결).
KRX_ID=여기에_실제_KRX_로그인_아이디_입력
KRX_PW=여기에_실제_KRX_로그인_비밀번호_입력

# OpenAI API(platform.openai.com) — scripts/gpt_review.py(GPT-5.6 Sol
# 독립 코드 리뷰 하네스)용. Claude Code Agent가 못 하는 타사 모델 리뷰용
OPENAI_API_KEY=여기에_실제_API_KEY_입력
